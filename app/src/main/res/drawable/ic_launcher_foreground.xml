<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Gemini Style Main Large Sparkle with Gradient Fill -->
    <path
        android:pathData="M 54,20 Q 54,54 20,54 Q 54,54 54,88 Q 54,54 88,54 Q 54,54 54,20 Z"
        android:strokeWidth="1"
        android:strokeColor="#00000000">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="54"
                android:endX="88"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF2D8CFF" /> <!-- Vibrant Blue -->
                <item android:offset="0.5" android:color="#FF9B72F8" /> <!-- Purple-Indigo -->
                <item android:offset="1.0" android:color="#FFF06292" /> <!-- Rose Coral -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Gemini Style Secondary Small Sparkle with Gradient Fill -->
    <path
        android:pathData="M 78,22 Q 78,34 66,34 Q 78,34 78,46 Q 78,34 90,34 Q 78,34 78,22 Z"
        android:strokeWidth="1"
        android:strokeColor="#00000000">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="66"
                android:startY="34"
                android:endX="90"
                android:endY="34"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF2D8CFF" />
                <item android:offset="0.5" android:color="#FF9B72F8" />
                <item android:offset="1.0" android:color="#FFF06292" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
